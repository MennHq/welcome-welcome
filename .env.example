# GEMINI_API_KEY: Required for Gemini AI API calls.
# Securely injected from your environment.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this application is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
# This variable can be useful when configuring OAuth or webhooks.
APP_URL="MY_APP_URL"

# SMTP_EMAIL: The email address to use for sending emails (e.g., your Google Workspace email)
SMTP_EMAIL=""

# SMTP_PASSWORD: The App Password for the email account
SMTP_PASSWORD=""

# WHOP_WEBHOOK_SECRET: Secret for verifying webhooks from Whop
WHOP_WEBHOOK_SECRET=""

# TOKEN_SECRET: Secure secret key used to sign and verify the download tokens
TOKEN_SECRET=""
